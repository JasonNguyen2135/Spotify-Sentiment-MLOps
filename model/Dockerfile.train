FROM python:3.10-slim

WORKDIR /app

# Cài đặt git và các thư viện cần thiết
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Cài đặt thư viện ML và DVC (để kéo dữ liệu)
RUN pip install --no-cache-dir \
    pandas \
    scikit-learn \
    mlflow \
    requests \
    python-dotenv \
    "dvc[s3]"

# Không copy code vì dùng InitContainer
CMD ["python", "train.py"]
