FROM python:3.10-slim

WORKDIR /app

# Cài đặt git và các thư viện cần thiết
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Cài đặt thư viện ML
RUN pip install --no-cache-dir \
    pandas \
    scikit-learn \
    mlflow \
    requests \
    python-dotenv

# Lưu ý: Chúng ta KHÔNG copy code vào đây 
# Vì code sẽ được InitContainer kéo từ Git về lúc chạy.

CMD ["python", "train.py"]
