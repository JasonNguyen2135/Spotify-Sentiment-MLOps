{
  "manifest_version": 3,
  "name": "SentimentAI Harvester",
  "version": "1.1",
  "description": "Scrape reviews from Google Play & App Store to CSV.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://play.google.com/*",
    "https://apps.apple.com/*"
  ]
}
